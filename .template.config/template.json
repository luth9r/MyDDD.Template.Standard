{
    "$schema": "http://json.schemastore.org/template",
    "author": "Luther",
    "classifications": [
        "Common",
        "DDD",
        "Aspire",
        "Vertical Slice"
    ],
    "name": "MyDDD Template Standard",
    "identity": "MyDDD.Template",
    "shortName": "myddd-std",
    "tags": {
        "language": "C#",
        "type": "project"
    },
    "sourceName": "MyDDD.Template",
    "preferNameDirectory": true,
    "sources": [
        {
            "modifiers": [
                {
                    "exclude": [
                        "**/[Bb]in/**",
                        "**/[Oo]bj/**",
                        ".git/**",
                        "**/.vs/**",
                        "**/.idea/**",
                        "**/*.user"
                    ]
                }
            ]
        }
    ],
    "symbols": {
        "Framework": {
            "type": "parameter",
            "description": "The target framework for the project.",
            "datatype": "string",
            "defaultValue": "net10.0"
        }
    }
}